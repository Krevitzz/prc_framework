import React from 'react';
import { FileJson, Info, AlertCircle, CheckCircle, TrendingUp } from 'lucide-react';

const EntityProfileTemplate = () => {
  // Template Jinja2 en commentaire (pour référence)
  const templateContent = `{# profile_entity.json.j2 - Profil entité individuel générique #}
{# Context attendu: entity_id, axis, tests_profiles, metadata #}
{
  "entity_id": "{{ entity_id }}",
  "axis": "{{ axis }}",
  "metadata": {
    "n_tests": {{ tests_profiles|length }},
    "n_total_runs": {{ metadata.n_total_runs }},
    "profiling_version": "{{ metadata.profiling_version }}",
    "profiling_module": "{{ metadata.profiling_module }}",
    "generated_at": "{{ metadata.generated_at }}"
  },
  "tests": {
{% for test_name, test_profile in tests_profiles.items() %}
    "{{ test_name }}": {
      "prc_profile": {
        "regime": "{{ test_profile.prc_profile.regime }}",
        "behavior": "{{ test_profile.prc_profile.behavior }}",
        "dominant_timeline": {
          "timeline_compact": "{{ test_profile.prc_profile.dominant_timeline.timeline_compact }}",
          "confidence": {{ test_profile.prc_profile.dominant_timeline.confidence }},
          "variants": {{ test_profile.prc_profile.dominant_timeline.variants|tojson }}
        },
        "robustness": {
          "homogeneous": {{ test_profile.prc_profile.robustness.homogeneous|tojson }},
          "mixed_behavior": {{ test_profile.prc_profile.robustness.mixed_behavior|tojson }},
          "numerically_stable": {{ test_profile.prc_profile.robustness.numerically_stable|tojson }}
        },
        "pathologies": {
          "numeric_instability": {{ test_profile.prc_profile.pathologies.numeric_instability|tojson }},
          "oscillatory": {{ test_profile.prc_profile.pathologies.oscillatory|tojson }},
          "collapse": {{ test_profile.prc_profile.pathologies.collapse|tojson }},
          "trivial": {{ test_profile.prc_profile.pathologies.trivial|tojson }},
          "degrading": {{ test_profile.prc_profile.pathologies.degrading|tojson }}
        },
        "n_runs": {{ test_profile.prc_profile.n_runs }},
        "n_valid": {{ test_profile.prc_profile.n_valid }},
        "confidence": "{{ test_profile.prc_profile.confidence }}",
        "confidence_metadata": {{ test_profile.prc_profile.confidence_metadata|tojson }}
      },
      "diagnostic_signature": {
        "dynamic_signature": {{ test_profile.diagnostic_signature.dynamic_signature|tojson }},
        "timeline_distribution": {{ test_profile.diagnostic_signature.timeline_distribution|tojson }},
        "run_dispersion": {{ test_profile.diagnostic_signature.run_dispersion|tojson }},
        "thresholds_used": {{ test_profile.diagnostic_signature.thresholds_used|tojson }}
      },
      "instrumentation": {
        "metric_name": "{{ test_profile.instrumentation.metric_name }}",
        "summary_metrics": {{ test_profile.instrumentation.summary_metrics|tojson }},
        "data_completeness": {{ test_profile.instrumentation.data_completeness|tojson }},
        "computation_metadata": {{ test_profile.instrumentation.computation_metadata|tojson }}
      }
    }{% if not loop.last %},{% endif %}
{% endfor %}
  },
  "summary": {
    "dominant_regime": "{{ summary.dominant_regime }}",
    "regime_distribution": {{ summary.regime_distribution|tojson }},
    "conserved_properties": {{ summary.conserved_properties|tojson }},
    "pathology_summary": {{ summary.pathology_summary|tojson }}
  }
}`;

