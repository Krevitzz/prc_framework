  const exampleData = {
    entity_id: "GAM-001",
    axis: "gamma",
    metadata: {
      n_tests: 9,
      n_total_runs: 270,
      profiling_version: "6.1",
      profiling_module: "profiling_common"
    },
    tests: {
      "SYM-001": {
        regime: "CONSERVES_SYMMETRY",
        behavior: "stable",
        confidence: "high",
        timeline: "early_deviation_then_saturation"
      },
      "SPE-001": {
        regime: "CONSERVES_NORM",
        behavior: "stable",
        confidence: "high",
        timeline: "no_significant_dynamics"
      },
      "TOP-001": {
        regime: "MIXED::OSCILLATORY_UNSTABLE",
        behavior: "mixed",
        confidence: "medium",
        timeline: "mid_instability_then_collapse"
      }
