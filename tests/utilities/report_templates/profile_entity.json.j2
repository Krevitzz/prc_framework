            Exemple : {exampleData.entity_id}
          </h2>
          
          <div className="space-y-4">
            <div className="flex items-center gap-2 text-sm text-slate-600">
              <TrendingUp className="w-4 h-4" />
              <span>Axe: {exampleData.axis}</span>
              <span className="mx-2">•</span>
              <span>{exampleData.metadata.n_tests} tests</span>
              <span className="mx-2">•</span>
              <span>{exampleData.metadata.n_total_runs} runs</span>
            </div>

            <div className="space-y-2">
              {Object.entries(exampleData.tests).map(([testName, testData]) => (
                <div key={testName} className="bg-slate-50 rounded p-3">
                  <div className="flex items-center justify-between mb-2">
                    <span className="font-mono text-sm font-semibold">{testName}</span>
                    <span className={`px-2 py-1 rounded text-xs font-medium ${
                      testData.behavior === 'stable' ? 'bg-green-100 text-green-800' :
                      testData.behavior === 'mixed' ? 'bg-orange-100 text-orange-800' :
                      'bg-red-100 text-red-800'
                    }`}>
                      {testData.behavior}
                    </span>
                  </div>
                  
                  <div className="grid grid-cols-2 gap-2 text-xs text-slate-600">
                    <div>
                      <span className="font-medium">Régime:</span> {testData.regime}
                    </div>
                    <div>
                      <span className="font-medium">Confidence:</span> {testData.confidence}
                    </div>
                    <div className="col-span-2">
                      <span className="font-medium">Timeline:</span> {testData.timeline}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Context Variables */}
        <div className="bg-white rounded-lg shadow-lg p-6 mb-6">
          <h2 className="text-xl font-semibold text-slate-800 mb-4">
            Variables Context Attendues
          </h2>
          
          <div className="bg-slate-900 rounded-lg p-4 overflow-x-auto">
            <pre className="text-green-400 text-sm font-mono">
{`{
  "entity_id": "GAM-001",           # ID entité
  "axis": "gamma",                  # Axe profiling
  "tests_profiles": {               # Dict profils tests
    "SYM-001": {
      "prc_profile": {...},         # Profil PRC complet
      "diagnostic_signature": {...},# Signature dynamique
      "instrumentation": {...}      # Métriques techniques
    },
    ...
  },
  "metadata": {
    "n_total_runs": 270,
    "profiling_version": "6.1",
    "profiling_module": "profiling_common",
    "generated_at": "2025-01-20T..."
  },
  "summary": {
    "dominant_regime": "CONSERVES_SYMMETRY",
    "regime_distribution": {...},
    "conserved_properties": [...],
    "pathology_summary": {...}
  }
}`}
            </pre>
          </div>
        </div>

        {/* Usage Notes */}
        <div className="bg-white rounded-lg shadow-lg p-6">
          <div className="flex items-center gap-2 mb-4">
            <AlertCircle className="w-5 h-5 text-amber-600" />
            <h2 className="text-xl font-semibold text-slate-800">
              Notes d'Utilisation
            </h2>
          </div>
          
          <div className="space-y-3 text-sm text-slate-600">
            <div className="flex gap-2">
              <CheckCircle className="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" />
              <div>
                <strong>Générique tous axes:</strong> Fonctionne identique pour gamma, modifier, encoding, test
              </div>
            </div>
            
            <div className="flex gap-2">
              <CheckCircle className="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" />
              <div>
                <strong>Structure normalisée:</strong> Conforme Charter R5.1-A (prc_profile, diagnostic_signature, instrumentation)
              </div>
            </div>
            
            <div className="flex gap-2">
              <CheckCircle className="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" />
              <div>
                <strong>JSON valide:</strong> Utilise filtres Jinja2 (tojson) pour sérialisation correcte
              </div>
            </div>
            
            <div className="flex gap-2">
              <CheckCircle className="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" />
              <div>
                <strong>Extensible:</strong> Section summary peut être enrichie selon axe (ex: discriminant_power pour tests)
              </div>
            </div>
          </div>
        </div>

        {/* Template Source (collapsed) */}
        <div className="bg-white rounded-lg shadow-lg p-6 mt-6">
          <details>
            <summary className="text-lg font-semibold text-slate-800 cursor-pointer hover:text-blue-600">
              📄 Source Template Jinja2 (cliquer pour afficher)
            </summary>
            <div className="mt-4 bg-slate-900 rounded-lg p-4 overflow-x-auto">
              <pre className="text-green-400 text-xs font-mono whitespace-pre">
                {templateContent}
              </pre>
            </div>
          </details>
        </div>
      </div>
    </div>
  );
};

export default EntityProfileTemplate;