            <Info className="w-5 h-5 text-blue-600" />
            <h2 className="text-xl font-semibold text-slate-800">
              Informations Template
            </h2>
          </div>
          
          <div className="grid grid-cols-2 gap-4">
            <div className="bg-slate-50 rounded p-4">
              <div className="text-sm text-slate-600 mb-1">Fichier</div>
              <div className="font-mono text-sm text-slate-800">
                profile_entity.json.j2
              </div>
            </div>
            
            <div className="bg-slate-50 rounded p-4">
              <div className="text-sm text-slate-600 mb-1">Type</div>
              <div className="font-mono text-sm text-slate-800">
                application/json (Jinja2)
              </div>
            </div>
            
            <div className="bg-slate-50 rounded p-4">
              <div className="text-sm text-slate-600 mb-1">Usage</div>
              <div className="font-mono text-sm text-slate-800">
                Tous axes (gamma, modifier, encoding, test)
              </div>
            </div>
            
            <div className="bg-slate-50 rounded p-4">
              <div className="text-sm text-slate-600 mb-1">Emplacement</div>
              <div className="font-mono text-sm text-slate-800">
                tests/utilities/report_templates/
              </div>
            </div>
          </div>
        </div>

        {/* Structure Output */}
        <div className="bg-white rounded-lg shadow-lg p-6 mb-6">
          <h2 className="text-xl font-semibold text-slate-800 mb-4">
            Structure Output JSON
          </h2>
          
          <div className="space-y-3">
            <div className="border-l-4 border-blue-500 bg-blue-50 p-3 rounded">
              <div className="font-semibold text-blue-900 mb-1">entity_id</div>
              <div className="text-sm text-blue-700">Identifiant entité (GAM-001, M1, SYM-001, etc.)</div>
            </div>
            
            <div className="border-l-4 border-green-500 bg-green-50 p-3 rounded">
              <div className="font-semibold text-green-900 mb-1">metadata</div>
              <div className="text-sm text-green-700">Infos profiling (n_tests, version, timestamps)</div>
            </div>
            
            <div className="border-l-4 border-purple-500 bg-purple-50 p-3 rounded">
              <div className="font-semibold text-purple-900 mb-1">tests</div>
              <div className="text-sm text-purple-700">
                Profils par test (prc_profile, diagnostic_signature, instrumentation)
              </div>
            </div>
            
            <div className="border-l-4 border-orange-500 bg-orange-50 p-3 rounded">
              <div className="font-semibold text-orange-900 mb-1">summary</div>
              <div className="text-sm text-orange-700">
                Régime dominant, propriétés conservées, pathologies
              </div>
            </div>
          </div>
        </div>

        {/* Exemple Visualisation */}
        <div className="bg-white rounded-lg shadow-lg p-6 mb-6">
